{
    "name": "collectioner",
    "private": true,
    "version": "1.0.0",
    "packageManager": "npm@11.9.0",
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev:backend": "npm run start:dev --workspace collectioner-backend",
        "build:backend": "npm run build --workspace collectioner-backend",
        "test:backend": "npm run test --workspace collectioner-backend",

        "dev:frontend": "npm run start --workspace frontend",
        "build:frontend": "npm run build --workspace frontend",
        "test:frontend": "npm run test --workspace frontend",

        "dev": "echo \"Run dev:frontend or dev:backend\"",
        "build": "npm run build:frontend && npm run build:backend",
        "test": "npm run test:frontend && npm run test:backend"
    }
}
